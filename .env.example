# Copy to .env (which is gitignored) and fill in real values.
# marketgoblin auto-loads .env from the working directory or any parent at
# package import time — no need to export these vars in your shell.

# Tiingo — required for `MarketGoblin(provider="tiingo")` and any of its
# fetch_* methods. Sign up at https://tiingo.com to get a key. SHARES,
# fetch_metadata (full mode), and fetch_classification require a paid tier.
TIINGO_API_KEY=your-tiingo-api-key-here
